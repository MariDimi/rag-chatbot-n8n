    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('When chat message received').item.json.chatInput }}",
        "options": {
          "systemMessage": "=Είσαι βοηθός σε μια ιστοσελίδα για το πρόγραμμα πρακτικής άσκησης του Δημοκριτείου Πανεπιστημίου Θράκης. Οι φοιτητές θα κάνουν ερωτήσεις σχετικά με το πρόγραμμα και εσύ θα απαντάς μόνο με την πληροφορία που παρέχεται στην βάση δεδομένων.\nΗ απάντηση πρέπει να είναι στα Ελληνικά.\nΗ απάντηση πρέπει πάντα να τελειώνει με ενότητα Πηγές: και το όνομα του εγγράφου που χρησιμοποιήθηκε ή το url αν υπαρχει.\n\nΥΠΟΧΡΕΩΤΙΚΗ ΜΟΡΦΗ ΕΞΟΔΟΥ\nΘα εμφανίζεις ΑΚΡΙΒΩΣ ΜΙΑ ΦΟΡΑ το tag <ΑΠΑΝΤΗΣΗ> και θα είναι η τελευταία ενότητα που γράφεις.\nΜΗΝ γράψεις το string <ΑΠΑΝΤΗΣΗ> πουθενά αλλού (ούτε σε οδηγίες, ούτε σε σκέψεις, ούτε σε παραδείγματα).\nΜετά το τελευταίο <ΑΠΑΝΤΗΣΗ> γράφεις μόνο το τελικό κείμενο της απάντησης.\nΜΗΝ γράφεις τίποτα μετά την απάντηση.\nΠαράδειγμα:\n<ΑΠΑΝΤΗΣΗ>\n(τελικό κείμενο απάντησης)\n\nΑν δεν βρίσκεις την απάντηση στη βάση δεδομένων ή δεν είσαι βέβαιος για αυτήν, τότε απάντησε ΑΚΡΙΒΩΣ το παρακάτω, πάλι μέσα στα tags:\n<ΑΠΑΝΤΗΣΗ>\nΠαρακαλώ επικοινωνήστε με το Κεντρικό Γραφείο Πρακτικής Άσκησης μέσω e-mail στο praktiki@duth.gr\n"
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 2,
      "position": [
        -480,
        1328
      ],
      "id": "13d45cc2-2612-4c3a-8d01-ecf439c23178",
      "name": "Generative Agent"
    },
    {
      "parameters": {
        "jsCode": "const raw = String($input.first().json.output || '');\n\nconst openTag = '<ΑΠΑΝΤΗΣΗ>';\nconst lastOpen = raw.lastIndexOf(openTag);\n\nlet answer = '';\n\nif (lastOpen !== -1) {\n  // Πάρε ΟΛΟ το κείμενο μετά το τελευταίο <ΑΠΑΝΤΗΣΗ>\n  answer = raw.slice(lastOpen + openTag.length);\n} else {\n  // Fallback: αν δεν υπάρχει καν tag\n  answer = raw;\n}\n\n// Μετατροπή \\n σε πραγματικά line breaks + καθάρισμα\nanswer = answer.replace(/\\\\n/g, '\\n').trim();\n\nreturn [\n  {\n    text: answer\n  }\n];\n"
      },
